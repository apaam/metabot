#compdef doubao-tts

# doubao-tts - Volcengine Doubao TTS CLI completion

_doubao-tts() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '-o[Output audio file]:output file:_files' \
        '--output[Output audio file]:output file:_files' \
        '-v[Voice/speaker ID]:voice:(zh_female_sajiaonvyou_moon_bigtts zh_female_gaolengyujie_moon_bigtts zh_female_tianmeixiaoyuan_moon_bigtts zh_female_yuanqinvyou_moon_bigtts zh_female_wanwanxiaohe_moon_bigtts zh_female_linjianvhai_moon_bigtts zh_male_aojiaobazong_moon_bigtts zh_male_jingqiangkanye_moon_bigtts zh_male_wennuanahu_moon_bigtts zh_male_yangguangqingnian_moon_bigtts)' \
        '--voice[Voice/speaker ID]:voice:(zh_female_sajiaonvyou_moon_bigtts zh_female_gaolengyujie_moon_bigtts zh_female_tianmeixiaoyuan_moon_bigtts zh_female_yuanqinvyou_moon_bigtts zh_female_wanwanxiaohe_moon_bigtts zh_female_linjianvhai_moon_bigtts zh_male_aojiaobazong_moon_bigtts zh_male_jingqiangkanye_moon_bigtts zh_male_wennuanahu_moon_bigtts zh_male_yangguangqingnian_moon_bigtts)' \
        '-f[Read text from file]:input file:_files -g "*.txt"' \
        '--file[Read text from file]:input file:_files -g "*.txt"' \
        '--speed[Speech speed (0.2-3)]:speed:' \
        '--volume[Volume (0.1-3)]:volume:' \
        '--pitch[Pitch (0.1-3)]:pitch:' \
        '--format[Audio format]:format:(mp3 wav)' \
        '-h[Show help]' \
        '--help[Show help]' \
        '*:text:'
}

compdef _doubao-tts doubao-tts
